{
  "name": "fynix-hub",
  "productName": "Fynix Hub",
  "version": "1.0.0",
  "description": "Media Hub with Netflix-like experience",
  "main": ".vite/build/index.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:flatpak": "electron-forge make --platform=linux --arch=x64",
