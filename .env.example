# TMDB API Key (required)
# Get yours at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_key_here

# Trakt API Credentials (optional, for scrobbling)
# Create an app at: https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=your_client_id_here
TRAKT_CLIENT_SECRET=your_client_secret_here

# Real-Debrid API Key (optional)
# Get from: https://real-debrid.com/apitoken
REAL_DEBRID_API_KEY=

# TorBox API Key (optional)
# Get from: https://torbox.app
TORBOX_API_KEY=
